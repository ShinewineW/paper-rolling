# config/campaign.yaml.example — TEMPLATE for the locked campaign parameters (吸收-D4).
#
# This is a TEMPLATE, not a live config. A fresh workspace ships NO live
# config/campaign.yaml, so `load_campaign()` returns None and the campaign Hard
# Gate fires on the first /loop tick (中枢-D1). The gate then WRITES the live
# config/campaign.yaml via `campaign.write_campaign()` with the locked fields
# below. Copy this file to config/campaign.yaml only if you want to seed it by
# hand. Daily /loop ticks read the live file and run autonomously WITHOUT
# re-gating; re-run the Hard Gate only to change topic or n_per_tick.
#
# The fields `campaign.load_campaign()` actually reads are: topic, n_per_tick,
# is_ad_domain, force_include. The remaining fields are discovery-policy overrides
# consumed by the discovery adapter / authority scorer (they have code defaults).

# --- Hard-Gate-confirmed (人在场显式钉死) — the locked CampaignConfig ---
# Precise, non-ambiguous research topic. The Hard Gate refuses vague topics
# (e.g. bare "autonomous driving") and forces a narrowed scope here.
topic: "PLACEHOLDER — set a precise topic at the campaign Hard Gate"

# auto_discover: true  = 自发查找 (discover by topic; force_include adds on top).
# auto_discover: false = 指定列表 (discovery OFF; force_include IS the whole work set, paged by n_per_tick).
auto_discover: true

# Per-tick target = number of SUCCESSFULLY processed papers each /loop tick
# (中枢-D2: failures are skipped and back-filled from the candidate pool).
# Also the cost / disk ceiling per tick (中枢-D1 side effect).
n_per_tick: 5

# Whether this campaign is autonomous-driving / robotics focused (toggles the
# AD-domain knowledge bases). The Hard Gate sets this when locking the campaign.
is_ad_domain: true

# Optional: papers that MUST be processed (中枢-D1), beyond autonomous discovery.
# Each entry needs BOTH (the Hard Gate rejects it otherwise):
#   1. an ingestible source the engine can fetch — arxiv_id OR oa_pdf_url
#      (a bare doi is NOT ingestible: there is no DOI->PDF resolver), and
#   2. a distinct identity — arxiv_id / doi / title (an oa_pdf_url-only entry must
#      add a title so two entries can't collide into one corpus dir / ledger key).
# They are prepended to the pool, bypass the authority filter, dedup vs discovery
# (discovery's PDF URL / venue / year are merged into the forced entry), and are
# all attempted this tick — but still go through ingest + G2 + G3.
force_include: []
#   - {arxiv_id: "2401.00001", title: "A must-include paper"}
#   - {oa_pdf_url: "https://example.org/paper.pdf", title: "Direct-PDF paper"}

# --- discovery policy ---
# 中枢-D5a / 吸收-D6: strict = preprints excluded from the authoritative set,
# logged status:deferred, auto-retried after the OpenAlex indexing lag (~21d).
preprint_policy: strict

# arXiv categories the discovery layer is restricted to (D-发现-3).
arxiv_categories:
  - cs.CV
  - cs.RO
  - cs.LG
  - cs.AI
  - eess.IV

# D-发现-2: OpenAlex polite-pool email -> ~10 req/s. Not a secret.
openalex_mailto: "ahhssxlcwjz@163.com"

# Top-tier venue allowlist — Tier-B authority signal S2 (D-发现-3/D-发现-5).
venue_allowlist:
  - NeurIPS
  - ICML
  - ICLR
  - CVPR
  - ICCV
  - ECCV
  - AAAI
  - ICRA
  - IROS
  - CoRL
  - RSS
  - TPAMI
  - IJCV
  - RA-L
  - T-RO

# Institution whitelist — authority signal S3 (D-发现-5). Matched against
# OpenAlex/S2 authorships[].institutions[].display_name (substring match).
institution_whitelist:
  - "Google"
  - "DeepMind"
  - "Meta"
  - "FAIR"
  - "NVIDIA"
  - "Microsoft Research"
  - "OpenAI"
  - "Apple"
  - "Amazon"
  - "Waymo"
  - "Tesla"
  - "Wayve"
  - "Cruise"
  - "Nuro"
  - "Toyota Research"
  - "Boston Dynamics"
  - "Allen Institute for AI"
  - "SenseTime"
  - "Megvii"
  - "Baidu"
  - "Huawei Noah"
  - "Horizon Robotics"
  - "Alibaba DAMO"
  - "Tencent AI Lab"
  - "ByteDance"
  - "Momenta"
  - "Pony.ai"
  - "Unitree"

# Authority multi-signal tuning (ADR-0001: no hard citation gate; OR model).
authority:
  # Discovery over-pulls 2-3x per_round_count so failed papers have back-fill
  # candidates (中枢-D2).
  candidate_multiplier: 3
  # Tier-B S2 influence threshold (recency-aware bar, ADR-0001 S1 helper).
  tierB_influence_threshold: 5
  # Recency weight applied in the composite top_k ranking (ADR-0001 S4).
  recency_weight: 0.3
  # Reserved quota for brand-new papers so classics don't crowd them out.
  new_paper_quota: 1
