# .env.example — copy to .env (gitignored) if you prefer env-based config.
#
# NOTE (D-发现-4): the shipped paper-landscape skill HARDCODES a fine-grained,
# READ-ONLY Hugging Face token directly in its source (user-forced, for
# self-contained distribution; blast radius limited to public-metadata reads).
# This .env path is provided as the env-based alternative for local overrides.

# Hugging Face API token — used only for HF Papers recall + code enrichment
# (D-发现-3). Anonymous access works; a read-only token raises rate limits.
HF_TOKEN=hf_your_read_only_token_here
