# .env.example — copy to .env (gitignored) ONLY to override the shipped token.
#
# NOTE (D-发现-4): the shipped paper-landscape source HARDCODES a fine-grained
# READ-ONLY HF token (owner-granted security.md exemption, for self-contained
# distribution; it lands in git history by design). You do NOT need to set
# anything to use HF Papers. Set HF_TOKEN below only to OVERRIDE the shipped token
# (env wins) without editing source. If the source constant is ever reset to the
# placeholder sentinel, HF requests fall back to anonymous (lower rate).

# Hugging Face API token (read-only) — overrides the hardcoded source token.
HF_TOKEN=hf_your_read_only_token_here
