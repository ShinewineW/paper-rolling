# .env.example — copy to .env (gitignored) and fill in your secrets.
#
# NOTE (D-发现-4): the HF token is read ONLY from this .env (HF_TOKEN); NOTHING is
# hardcoded in source — an earlier shipped constant was auto-revoked by Hugging
# Face the moment it hit public git history. Set a READ-ONLY HF_TOKEN below to
# authenticate HF Papers discovery + githubRepo enrichment. Leave it unset (keep
# the line commented) to run ANONYMOUSLY — HF search still works at a lower rate.

# Hugging Face API token (read-only). Uncomment and set to authenticate; unset = anonymous.
# HF_TOKEN=hf_your_read_only_token_here
