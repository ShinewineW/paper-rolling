# .env.example — copy to .env (gitignored) if you prefer env-based config.
#
# NOTE (D-发现-4): the shipped paper-landscape source carries a PLACEHOLDER HF
# token (`hf_REPLACE_WITH_READONLY_TOKEN` in discovery/hf_papers.py) — replace it
# in source with a fine-grained READ-ONLY token for self-contained distribution,
# or set HF_TOKEN below (env wins). Anonymous access also works (lower rate
# limits); blast radius is public-metadata reads only.

# Hugging Face API token — used only for HF Papers recall + code enrichment
# (D-发现-3). Anonymous access works; a read-only token raises rate limits.
HF_TOKEN=hf_your_read_only_token_here
